   "source": [
    "import pandas as pd\n",
    "\n",
    "activities = client.get_activities(0, 582)\n",
    "\n",
    "df_raw = pd.DataFrame(activities)\n",
    "\n",
    "relevante_kolommen = [\n",
    "    'startTimeLocal', \n",
    "    'distance', \n",
    "    'duration', \n",
    "    'averageHR', \n",
    "    'maxHR' \n",
    "]\n",
    "\n",
    "bestaande_kolommen = [col for col in relevante_kolommen if col in df_raw.columns]\n",
    "\n",
    "df_raw[bestaande_kolommen].head()"
   ]
  },
